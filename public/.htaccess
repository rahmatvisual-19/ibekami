<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>
    
    # 🚫 Batasi agar hanya domain ibeka.id yang bisa mengakses
    RewriteCond %{HTTP_HOST} !^ibekami\.id$ [NC]
    RewriteCond %{HTTP_HOST} !^www\.ibekami\.id$ [NC]
    RewriteRule ^ - [F]

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Ensure WebP files are served with the correct MIME type
# This guarantees browsers treat .webp as image/webp, enabling "Save Image As .webp"
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>

# ─── Gzip Compression ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff
    AddOutputFilterByType DEFLATE text/xml application/xhtml+xml
    
    # Compress HTML output
    SetOutputFilter DEFLATE
    
    # Don't compress images (already compressed)
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp)$ no-gzip dont-vary
    
    # Make sure proxies don't deliver wrong content
    Header append Vary User-Agent env=!dont-vary
</IfModule>

# ─── Brotli Compression (jika tersedia, lebih baik dari Gzip) ────────────────
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css
    AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
    AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ─── Browser Cache Headers ────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Images & video — 1 year
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType video/mp4           "access plus 1 year"
    ExpiresByType video/webm          "access plus 1 year"
    # CSS & JS — 1 month (versioned via query string)
    ExpiresByType text/css            "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    # Fonts — 1 year
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType font/woff           "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control untuk static assets
    <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|mp4|webm|woff2|woff)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    
    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove ETag (sudah ada Cache-Control)
    Header unset ETag
    FileETag None
    
    # Preload hint untuk critical resources
    <FilesMatch "\.html$">
        Header add Link "</css/vendor/bootstrap.min.css>; rel=preload; as=style"
        Header add Link "</css/style.css>; rel=preload; as=style"
    </FilesMatch>
</IfModule>
