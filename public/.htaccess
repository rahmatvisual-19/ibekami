<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>
    
    # 🚫 Batasi agar hanya domain ibeka.id yang bisa mengakses
    RewriteCond %{HTTP_HOST} !^ibekami\.id$ [NC]
    RewriteCond %{HTTP_HOST} !^www\.ibekami\.id$ [NC]
    RewriteRule ^ - [F]

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Ensure WebP files are served with the correct MIME type
# This guarantees browsers treat .webp as image/webp, enabling "Save Image As .webp"
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>

# ─── Gzip Compression ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff
</IfModule>

# ─── Browser Cache Headers ────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Images & video — 1 year
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType video/mp4           "access plus 1 year"
    ExpiresByType video/webm          "access plus 1 year"
    # CSS & JS — 1 month (versioned via query string)
    ExpiresByType text/css            "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    # Fonts — 1 year
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType font/woff           "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|mp4|webm|woff2|woff)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>
